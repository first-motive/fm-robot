# Level 3 (leaf) — hardware abstraction. sim_backend selects one <hardware>
# plugin; all five implement the same ros2_control SystemInterface, so one line
# runs in from Backend Select and one line out to the Control Interface.
# Everything above the interface is identical. The five backend blocks nest
# inside one Backends block. Each block: engine name (role), plugin class (art).
...@styles
direction: right

arg: "" {
  grid-rows: 2
  class: block
  r: Backend Select { class: role }
  a: sim_backend { class: art }
}

backends: Backends {
  class: block
  mock: "" {
    grid-rows: 2
    class: block
    r: Mock { class: role }
    a: GenericSystem { class: art }
  }
  mujoco: "" {
    grid-rows: 2
    class: block
    r: MuJoCo { class: role }
    a: MujocoSystemInterface { class: art }
  }
  gazebo: "" {
    grid-rows: 2
    class: block
    r: Gazebo { class: role }
    a: GazeboSimSystem { class: art }
  }
  isaac: "" {
    grid-rows: 2
    class: block
    r: Isaac { class: role }
    a: TopicBasedSystem { class: art }
  }
  real: "" {
    grid-rows: 2
    class: block
    r: Real { class: role }
    a: SystemInterface { class: art }
  }
}

iface: "" {
  grid-rows: 2
  class: block
  r: Control Interface { class: role }
  a: ros2_control system { class: art }
}

arg -> backends -> iface
