# Level 3 (leaf) — hardware abstraction. The sim_backend arg selects the
# <hardware> plugin behind one ros2_control system interface. Sim engines and
# real hardware are interchangeable; everything above the interface is identical.
# Each block: engine name (role), plugin type (art).
...@styles
direction: right

arg: "" {
  grid-rows: 2
  class: block
  r: Backend Select { class: role }
  a: sim_backend { class: art }
}
mock: "" {
  grid-rows: 2
  class: block
  r: Mock { class: role }
  a: GenericSystem { class: art }
}
mujoco: "" {
  grid-rows: 2
  class: block
  r: MuJoCo { class: role }
  a: MujocoSystemInterface { class: art }
}
gazebo: "" {
  grid-rows: 2
  class: block
  r: Gazebo { class: role }
  a: GazeboSimSystem { class: art }
}
isaac: "" {
  grid-rows: 2
  class: block
  r: Isaac { class: role }
  a: TopicBasedSystem { class: art }
}
real: "" {
  grid-rows: 2
  class: block
  r: Real { class: role }
  a: "OpenArmHW · g1 bridge" { class: art }
}
iface: "" {
  grid-rows: 2
  class: block
  r: Control Interface { class: role }
  a: ros2_control system { class: art }
}

arg -> mock -> iface
arg -> mujoco -> iface
arg -> gazebo -> iface
arg -> isaac -> iface
arg -> real -> iface
