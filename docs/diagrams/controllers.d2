# Controllers / sim stack — the ros2_control graph fm_bringup brings up. The
# controllers run inside the controller_manager (loaded plugins): the robot
# controller (the one that robot uses) subscribes a command; joint_state_broadcaster
# publishes /joint_states. robot_state_publisher subscribes /joint_states and
# publishes /robot_description + TF. The controller_manager receives the
# description as a launch parameter, so there is no /robot_description topic edge
# into it. Nodes are plum boxes, topics cream pills.
...@styles
direction: right

cmd: /robot_controller/command { class: topic }
js: /joint_states { class: topic }
rd: /robot_description { class: topic }
tf: /tf { class: topic }
tfs: /tf_static { class: topic }

cm: controller_manager {
  grid-rows: 2
  ctrl: robot_controller { class: node }
  jsb: joint_state_broadcaster { class: node }
}
rsp: robot_state_publisher { class: node }

cmd -> cm.ctrl
cm.jsb -> js
js -> rsp
rsp -> rd
rsp -> tf
rsp -> tfs
